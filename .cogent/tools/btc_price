#!/bin/bash
# @tool btc_price
# @description Get the current spot price of Bitcoin (BTC) in a given currency using the Coinbase API.
# @param currency string "Target currency code, e.g. USD, EUR, GBP (default: USD)"
# @noconfirm

INPUT=$(cat)
CURRENCY=$(echo "$INPUT" | sed -n 's/.*"currency"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')

if [ -z "$CURRENCY" ]; then
  CURRENCY="USD"
fi

CURRENCY=$(echo "$CURRENCY" | tr '[:lower:]' '[:upper:]')

RESPONSE=$(curl -sf "https://api.coinbase.com/v2/prices/BTC-${CURRENCY}/spot")

if [ $? -ne 0 ] || [ -z "$RESPONSE" ]; then
  echo "Error: failed to fetch BTC price for currency '${CURRENCY}'. Ensure it is a valid currency code." >&2
  exit 1
fi

AMOUNT=$(echo "$RESPONSE" | sed -n 's/.*"amount":"\([^"]*\)".*/\1/p')

if [ -z "$AMOUNT" ]; then
  echo "Error: could not parse BTC price from API response: $RESPONSE" >&2
  exit 1
fi

echo "Bitcoin price: ${AMOUNT} ${CURRENCY}"
