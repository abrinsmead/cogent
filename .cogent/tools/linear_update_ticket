#!/bin/bash
# @tool linear_update_ticket
# @description Update a Linear ticket's status, title, priority, and/or assignee. Requires at least one field to update.
# @param ticket_id string required "The ticket identifier, e.g. ABR-15"
# @param status string "New status name, e.g. 'Done', 'In Progress', 'Todo', 'Backlog', 'Canceled'"
# @param title string "New title for the ticket"
# @param priority string "Priority level: 'None', 'Urgent', 'High', 'Medium', 'Low'"
# @param assignee string "Assignee name or display name (looked up by fuzzy match)"
# @env LINEAR_API_KEY required "Linear API key (personal or OAuth token)"
# @confirm

set -euo pipefail

INPUT=$(cat)

TICKET_ID=$(echo "$INPUT" | sed -n 's/.*"ticket_id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
STATUS=$(echo "$INPUT" | sed -n 's/.*"status"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
TITLE=$(echo "$INPUT" | sed -n 's/.*"title"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
PRIORITY=$(echo "$INPUT" | sed -n 's/.*"priority"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
ASSIGNEE=$(echo "$INPUT" | sed -n 's/.*"assignee"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')

if [ -z "$LINEAR_API_KEY" ]; then
  echo "Error: LINEAR_API_KEY environment variable is not set." >&2
  exit 1
fi

if [ -z "$TICKET_ID" ]; then
  echo "Error: ticket_id is required (e.g. ABR-15)." >&2
  exit 1
fi

if [ -z "$STATUS" ] && [ -z "$TITLE" ] && [ -z "$PRIORITY" ] && [ -z "$ASSIGNEE" ]; then
  echo "Error: at least one field to update is required (status, title, priority, or assignee)." >&2
  exit 1
fi

# Uppercase the ticket ID
TICKET_ID=$(echo "$TICKET_ID" | tr '[:lower:]' '[:upper:]')
TEAM_KEY=$(echo "$TICKET_ID" | sed 's/-.*//')
ISSUE_NUM=$(echo "$TICKET_ID" | sed 's/.*-//')

# --- Step 1: Look up the issue ID ---

ISSUE_QUERY=$(cat <<EOF
{"query":"{ issues(filter: { team: { key: { eq: \"$TEAM_KEY\" } }, number: { eq: $ISSUE_NUM } }) { nodes { id identifier title state { name } team { id } } } }"}
EOF
)

ISSUE_RESPONSE=$(curl -sf -X POST "https://api.linear.app/graphql" \
  -H "Content-Type: application/json" \
  -H "Authorization: $LINEAR_API_KEY" \
  -d "$ISSUE_QUERY")

if [ $? -ne 0 ] || [ -z "$ISSUE_RESPONSE" ]; then
  echo "Error: failed to fetch ticket from Linear API." >&2
  exit 1
fi

ISSUE_INFO=$(echo "$ISSUE_RESPONSE" | python3 -c "
import sys, json
d = json.load(sys.stdin)
if 'errors' in d:
    for e in d['errors']:
        print('Error:', e.get('message','unknown'), file=sys.stderr)
    sys.exit(1)
nodes = d.get('data', {}).get('issues', {}).get('nodes', [])
if not nodes:
    print('Error: no ticket found matching $TICKET_ID.', file=sys.stderr)
    sys.exit(1)
issue = nodes[0]
print(issue['id'])
print(issue['team']['id'])
" 2>&1)

if [ $? -ne 0 ]; then
  echo "$ISSUE_INFO" >&2
  exit 1
fi

ISSUE_ID=$(echo "$ISSUE_INFO" | sed -n '1p')
TEAM_ID=$(echo "$ISSUE_INFO" | sed -n '2p')

# --- Step 2: Resolve status to state ID ---

STATE_ID=""
if [ -n "$STATUS" ]; then
  STATES_QUERY="{\"query\":\"{ team(id: \\\"$TEAM_ID\\\") { states { nodes { id name } } } }\"}"

  STATES_RESPONSE=$(curl -sf -X POST "https://api.linear.app/graphql" \
    -H "Content-Type: application/json" \
    -H "Authorization: $LINEAR_API_KEY" \
    -d "$STATES_QUERY")

  if [ $? -ne 0 ] || [ -z "$STATES_RESPONSE" ]; then
    echo "Error: failed to fetch workflow states from Linear API." >&2
    exit 1
  fi

  STATE_ID=$(echo "$STATES_RESPONSE" | python3 -c "
import sys, json
d = json.load(sys.stdin)
if 'errors' in d:
    for e in d['errors']:
        print('Error:', e.get('message','unknown'), file=sys.stderr)
    sys.exit(1)
target = '${STATUS}'.lower()
for s in d['data']['team']['states']['nodes']:
    if s['name'].lower() == target:
        print(s['id'])
        sys.exit(0)
names = [s['name'] for s in d['data']['team']['states']['nodes']]
print('Error: status \'${STATUS}\' not found. Available: ' + ', '.join(names), file=sys.stderr)
sys.exit(1)
" 2>&1)

  if [ $? -ne 0 ]; then
    echo "$STATE_ID" >&2
    exit 1
  fi
fi

# --- Step 3: Resolve assignee to user ID ---

USER_ID=""
if [ -n "$ASSIGNEE" ]; then
  USERS_QUERY="{\"query\":\"{ users { nodes { id name displayName } } }\"}"

  USERS_RESPONSE=$(curl -sf -X POST "https://api.linear.app/graphql" \
    -H "Content-Type: application/json" \
    -H "Authorization: $LINEAR_API_KEY" \
    -d "$USERS_QUERY")

  if [ $? -ne 0 ] || [ -z "$USERS_RESPONSE" ]; then
    echo "Error: failed to fetch users from Linear API." >&2
    exit 1
  fi

  USER_ID=$(echo "$USERS_RESPONSE" | python3 -c "
import sys, json
d = json.load(sys.stdin)
if 'errors' in d:
    for e in d['errors']:
        print('Error:', e.get('message','unknown'), file=sys.stderr)
    sys.exit(1)
target = '${ASSIGNEE}'.lower()
for u in d['data']['users']['nodes']:
    if target in u['name'].lower() or target in u.get('displayName','').lower():
        print(u['id'])
        sys.exit(0)
names = [u['name'] for u in d['data']['users']['nodes']]
print('Error: no user found matching \'${ASSIGNEE}\'. Available: ' + ', '.join(names), file=sys.stderr)
sys.exit(1)
" 2>&1)

  if [ $? -ne 0 ]; then
    echo "$USER_ID" >&2
    exit 1
  fi
fi

# --- Step 4: Map priority to integer ---

PRIORITY_NUM=""
if [ -n "$PRIORITY" ]; then
  PRIORITY_LOWER=$(echo "$PRIORITY" | tr '[:upper:]' '[:lower:]')
  case "$PRIORITY_LOWER" in
    none|no\ priority) PRIORITY_NUM="0" ;;
    urgent)            PRIORITY_NUM="1" ;;
    high)              PRIORITY_NUM="2" ;;
    medium)            PRIORITY_NUM="3" ;;
    low)               PRIORITY_NUM="4" ;;
    *)
      echo "Error: invalid priority '$PRIORITY'. Must be one of: None, Urgent, High, Medium, Low." >&2
      exit 1
      ;;
  esac
fi

# --- Step 5: Build the mutation input fields ---

INPUT_FIELDS=""

if [ -n "$STATE_ID" ]; then
  INPUT_FIELDS="${INPUT_FIELDS} stateId: \\\"$STATE_ID\\\","
fi

if [ -n "$TITLE" ]; then
  # Escape quotes in title
  ESCAPED_TITLE=$(echo "$TITLE" | sed 's/\\/\\\\/g; s/"/\\"/g')
  INPUT_FIELDS="${INPUT_FIELDS} title: \\\"$ESCAPED_TITLE\\\","
fi

if [ -n "$PRIORITY_NUM" ]; then
  INPUT_FIELDS="${INPUT_FIELDS} priority: $PRIORITY_NUM,"
fi

if [ -n "$USER_ID" ]; then
  INPUT_FIELDS="${INPUT_FIELDS} assigneeId: \\\"$USER_ID\\\","
fi

# Remove trailing comma
INPUT_FIELDS=$(echo "$INPUT_FIELDS" | sed 's/,$//')

# --- Step 6: Execute the mutation ---

MUTATION="{\"query\":\"mutation { issueUpdate(id: \\\"$ISSUE_ID\\\", input: {$INPUT_FIELDS }) { success issue { identifier title state { name } priorityLabel assignee { name } url } } }\"}"

MUTATION_RESPONSE=$(curl -sf -X POST "https://api.linear.app/graphql" \
  -H "Content-Type: application/json" \
  -H "Authorization: $LINEAR_API_KEY" \
  -d "$MUTATION")

if [ $? -ne 0 ] || [ -z "$MUTATION_RESPONSE" ]; then
  echo "Error: failed to update ticket via Linear API." >&2
  exit 1
fi

# --- Step 7: Format output ---

echo "$MUTATION_RESPONSE" | python3 -c "
import sys, json

d = json.load(sys.stdin)

if 'errors' in d:
    for e in d['errors']:
        print('Error:', e.get('message','unknown'), file=sys.stderr)
    sys.exit(1)

result = d.get('data', {}).get('issueUpdate', {})
if not result.get('success'):
    print('Error: update was not successful.', file=sys.stderr)
    sys.exit(1)

issue = result.get('issue', {})
identifier = issue.get('identifier', '?')
title = issue.get('title', 'Untitled')
state = issue.get('state', {}).get('name', 'Unknown')
priority = issue.get('priorityLabel', 'None')
assignee = issue.get('assignee', {})
assignee_name = assignee.get('name', 'Unassigned') if assignee else 'Unassigned'
url = issue.get('url', '')

print(f'Updated [{identifier}] successfully.')
print()
print(f'  Title:     {title}')
print(f'  Status:    {state}')
print(f'  Priority:  {priority}')
print(f'  Assignee:  {assignee_name}')
print(f'  {url}')
"
