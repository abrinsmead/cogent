#!/bin/bash
# @tool linear_tickets
# @description Get Linear tickets assigned to a user. Returns ticket ID, title, status, priority, and URL. Uses LINEAR_USERNAME from .env by default. Falls back to the authenticated user (API key owner) if neither is set.
# @param username string "Override: look up another user's tickets by name. Defaults to LINEAR_USERNAME from .env."
# @param status string "Filter by status name, e.g. 'In Progress', 'Todo', 'Done'. Leave empty for all statuses."
# @param limit string "Max number of tickets to return (default: 50)"
# @env LINEAR_API_KEY required "Linear API key (personal or OAuth token)"
# @env LINEAR_USERNAME "Default Linear username or display name. Set in .cogent/.env to avoid passing it each time."
# @noconfirm

set -euo pipefail

INPUT=$(cat)

USERNAME=$(echo "$INPUT" | sed -n 's/.*"username"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
STATUS=$(echo "$INPUT" | sed -n 's/.*"status"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
LIMIT=$(echo "$INPUT" | sed -n 's/.*"limit"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')

# Fall back to LINEAR_USERNAME from .env if no param provided
if [ -z "$USERNAME" ] && [ -n "${LINEAR_USERNAME:-}" ]; then
  USERNAME="$LINEAR_USERNAME"
fi

if [ -z "$LINEAR_API_KEY" ]; then
  echo "Error: LINEAR_API_KEY environment variable is not set." >&2
  exit 1
fi

if [ -z "$LIMIT" ]; then
  LIMIT="50"
fi

# Build the assignee filter
if [ -z "$USERNAME" ]; then
  # No username — get the authenticated user's ID first
  ME_QUERY='{"query":"{ viewer { id name } }"}'
  ME_RESPONSE=$(curl -sf -X POST "https://api.linear.app/graphql" \
    -H "Content-Type: application/json" \
    -H "Authorization: $LINEAR_API_KEY" \
    -d "$ME_QUERY")

  if [ $? -ne 0 ] || [ -z "$ME_RESPONSE" ]; then
    echo "Error: failed to fetch authenticated user from Linear API." >&2
    exit 1
  fi

  USER_ID=$(echo "$ME_RESPONSE" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['data']['viewer']['id'])" 2>/dev/null)
  USER_NAME=$(echo "$ME_RESPONSE" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['data']['viewer']['name'])" 2>/dev/null)

  if [ -z "$USER_ID" ]; then
    echo "Error: could not determine authenticated user. API response: $ME_RESPONSE" >&2
    exit 1
  fi
  ASSIGNEE_FILTER="assignee: { id: { eq: \\\"$USER_ID\\\" } }"
else
  # Search for user by name
  USERS_QUERY="{\"query\":\"{ users { nodes { id name displayName } } }\"}"
  USERS_RESPONSE=$(curl -sf -X POST "https://api.linear.app/graphql" \
    -H "Content-Type: application/json" \
    -H "Authorization: $LINEAR_API_KEY" \
    -d "$USERS_QUERY")

  if [ $? -ne 0 ] || [ -z "$USERS_RESPONSE" ]; then
    echo "Error: failed to fetch users from Linear API." >&2
    exit 1
  fi

  USER_ID=$(echo "$USERS_RESPONSE" | python3 -c "
import sys, json
data = json.load(sys.stdin)
target = '${USERNAME}'.lower()
for u in data['data']['users']['nodes']:
    if target in u['name'].lower() or target in u.get('displayName','').lower():
        print(u['id'])
        break
" 2>/dev/null)

  if [ -z "$USER_ID" ]; then
    echo "Error: no user found matching '${USERNAME}'." >&2
    exit 1
  fi
  USER_NAME="$USERNAME"
  ASSIGNEE_FILTER="assignee: { id: { eq: \\\"$USER_ID\\\" } }"
fi

# Build optional status filter
STATUS_FILTER=""
if [ -n "$STATUS" ]; then
  STATUS_FILTER=", state: { name: { eqCaseInsensitive: \\\"$STATUS\\\" } }"
fi

# Fetch tickets
QUERY="{\"query\":\"{ issues(first: $LIMIT, filter: { $ASSIGNEE_FILTER $STATUS_FILTER }) { nodes { identifier title priority priorityLabel state { name } url team { key name } labels { nodes { name } } createdAt updatedAt } } }\"}"

RESPONSE=$(curl -sf -X POST "https://api.linear.app/graphql" \
  -H "Content-Type: application/json" \
  -H "Authorization: $LINEAR_API_KEY" \
  -d "$QUERY")

if [ $? -ne 0 ] || [ -z "$RESPONSE" ]; then
  echo "Error: failed to fetch tickets from Linear API." >&2
  exit 1
fi

# Check for GraphQL errors
HAS_ERRORS=$(echo "$RESPONSE" | python3 -c "
import sys, json
d = json.load(sys.stdin)
if 'errors' in d:
    for e in d['errors']:
        print('Error:', e.get('message','unknown'))
    sys.exit(1)
" 2>&1)

if [ $? -ne 0 ]; then
  echo "$HAS_ERRORS" >&2
  echo "Raw response: $RESPONSE" >&2
  exit 1
fi

# Format output
echo "$RESPONSE" | python3 -c "
import sys, json

data = json.load(sys.stdin)
issues = data.get('data', {}).get('issues', {}).get('nodes', [])

if not issues:
    print('No tickets found.')
    sys.exit(0)

print(f'Found {len(issues)} ticket(s) for ${USER_NAME:-\"user\"}:')
print()

for issue in issues:
    identifier = issue.get('identifier', '?')
    title = issue.get('title', 'Untitled')
    state = issue.get('state', {}).get('name', 'Unknown')
    priority = issue.get('priorityLabel', 'None')
    url = issue.get('url', '')
    team = issue.get('team', {}).get('name', '')
    labels = ', '.join(l['name'] for l in issue.get('labels', {}).get('nodes', []))

    print(f'  [{identifier}] {title}')
    print(f'    Status: {state} | Priority: {priority} | Team: {team}')
    if labels:
        print(f'    Labels: {labels}')
    print(f'    {url}')
    print()
"
